---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="description"
      content="Gestiòn estrategicas de compras para 
	mipymes y emprendedores."
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Sagil Solutions</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    {/* Botón Flotante de WhatsApp Global */}
    <a
      href="https://wa.me/1234567890?text=Hola,%20quiero%20optimizar%20mis%20compras"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 md:bottom-8 md:right-8 z-[90] bg-[#25D366] hover:bg-[#128C7E] text-white p-3 md:p-4 rounded-full shadow-[0_4px_14px_0_rgba(37,211,102,0.5)] hover:shadow-[0_6px_24px_rgba(37,211,102,0.8)] transition-all duration-300 hover:-translate-y-1 hover:scale-110 flex items-center justify-center group"
      aria-label="Chat en WhatsApp"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-8 h-8 md:w-9 md:h-9"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
        <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
        <path
          d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"
        ></path>
      </svg>
    </a>
  </body>
</html>

<style is:global></style>
