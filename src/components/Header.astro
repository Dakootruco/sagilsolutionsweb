---
import sagilLogo from "../assets/SAGIL.png";
---

<header
  class="w-full bg-[#ffffff] py-2 md:py-4 shadow-sm border-b border-gray-100 sticky top-0 z-50"
>
  <div
    class="max-w-[1440px] mx-auto px-6 md:px-8 flex justify-between items-center"
  >
    <!-- Header Logo -->
    <a
      href="/"
      class="flex items-center transition-transform duration-300 hover:scale-[1.02]"
    >
      <img
        class="w-30 md:w-20 lg:w-32 max-h-16 md:max-h-20 object-contain"
        src={sagilLogo.src}
        alt="Logo Sagil Solutions"
      />
    </a>
    <!-- Menú de Navegación -->
    <nav class="hidden md:block">
      <ul class="flex items-center gap-8">
        <li>
          <a
            href="#servicios"
            class="text-sm font-medium text-[#003061] hover:text-[#001B3C] transition-colors tracking-wide relative group"
          >
            Servicios
            <span
              class="absolute -bottom-1.5 left-0 w-0 h-[2px] bg-green-500 transition-all duration-300 group-hover:w-full"
            ></span>
          </a>
        </li>
        <li>
          <a
            href="#nosotros"
            class="text-sm font-medium text-[#003061] hover:text-[#001B3C] transition-colors tracking-wide relative group"
          >
            Nosotros
            <span
              class="absolute -bottom-1.5 left-0 w-0 h-[2px] bg-green-500 transition-all duration-300 group-hover:w-full"
            ></span>
          </a>
        </li>
        <li>
          <a
            href="#contacto"
            class="bg-[#22c55e] hover:bg-[#16a34a] text-white text-sm font-bold px-6 py-2.5 rounded-lg transition-all duration-300 shadow-[0_4px_14px_0_rgba(34,197,94,0.39)] hover:shadow-[0_6px_20px_rgba(34,197,94,0.23)] hover:-translate-y-0.5"
          >
            Contacto
          </a>
        </li>
      </ul>
    </nav>

    <!-- Menú Mobile -->

    <button
      onclick="toggleMenu()"
      class="md:hidden text-[#003061] hover:text-[#001B3C] p-2"
      aria-label="Abrir menú"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <!-- Menú Mobile Dropdown (Desplegable) -->
  <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-white shadow-xl shadow-black/5 border-t border-gray-100 flex-col items-center py-8 gap-6 z-40 origin-top">
    <a href="#servicios" onclick="toggleMenu()" class="text-lg font-medium text-[#003061] hover:text-[#001B3C] w-full text-center py-2 transition-colors">Servicios</a>
    <a href="#nosotros" onclick="toggleMenu()" class="text-lg font-medium text-[#003061] hover:text-[#001B3C] w-full text-center py-2 transition-colors">Nosotros</a>
    <a href="#contacto" onclick="toggleMenu()" class="bg-[#22c55e] hover:bg-[#16a34a] text-white text-lg font-bold px-10 py-3 rounded-xl transition-all shadow-[0_4px_14px_0_rgba(34,197,94,0.39)] mt-2">Contacto</a>
  </div>
</header>

<script is:inline>
  // Definir la función globalmente para el onclick
  window.toggleMenu = function() {
    const menu = document.getElementById('mobile-menu');
    if (menu) {
      // Alternamos entre oculto (hidden) y visible (flex)
      menu.classList.toggle('hidden');
      menu.classList.toggle('flex');
    }
  }
</script>
