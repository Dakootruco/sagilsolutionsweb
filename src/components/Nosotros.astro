---
// Nosotros.astro
import logo from "../assets/SAGIL.png";
import logo2 from "../assets/SAGIL-Gestion.png";
---

<section id="nosotros" class="py-20 bg-gray-50 overflow-hidden">
    <div class="max-w-[1440px] mx-auto px-6 md:px-8 lg:px-12">
        <div
            class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center"
        >
            {/* Contenido Izquierda: Imagen + Sello */}
            <div
                class="relative w-full h-[400px] md:h-[600px] rounded-3xl overflow-hidden shadow-2xl group animate-fade-in-down delay-100 order-2 lg:order-1"
            >
                {/* Imagen tipo empresarial/logística */}
                {
                    /* Usamos una imagen de Unsplash de logística de contenedores/transporte internacional */
                }
                <img
                    src="https://images.unsplash.com/photo-1578575437130-527eed3abbec?auto=format&fit=crop&q=80"
                    alt="Operaciones de logística internacional Sagil"
                    class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
                />

                {/* Gradiente oscuro para mejor contraste en la base */}
                <div
                    class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-[#003061]/90 to-transparent"
                >
                </div>

                {/* Sello flontante "Experiencia internacional" */}
                <div
                    class="absolute bottom-6 left-6 md:bottom-10 md:left-10 bg-white/95 backdrop-blur-md p-4 rounded-2xl shadow-xl flex items-center gap-4 transition-transform duration-300 hover:-translate-y-1"
                >
                    <div
                        class="w-12 h-12 bg-blue-50 rounded-full flex items-center justify-center flex-shrink-0 border border-blue-100"
                    >
                        <svg
                            class="w-6 h-6 text-blue-600"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <p
                            class="font-extrabold text-[#003061] text-sm md:text-base leading-tight uppercase tracking-wide"
                        >
                            Experiencia<br /><span class="text-blue-600"
                                >Internacional</span
                            >
                        </p>
                    </div>
                </div>
            </div>

            {/* Contenido Derecha: Textos y Bullets */}
            <div
                class="flex flex-col justify-center animate-fade-in-down delay-200 order-1 lg:order-2"
            >
                <h2
                    class="text-sm font-bold text-blue-600 tracking-widest uppercase mb-3"
                >
                    Sobre nosotros
                </h2>
                <h3
                    class="text-4xl md:text-5xl font-extrabold text-[#003061] tracking-tight mb-8 leading-tight"
                >
                    ¿Por qué Sagil?
                </h3>

                {/* Textos: estrictamente 2 párrafos máximos */}
                <div
                    class="space-y-6 text-lg md:text-xl text-gray-600 leading-relaxed mb-10 font-light"
                >
                    <p>
                        En <span class="font-bold text-[#003061]">Sagil</span> ayudamos
                        a mipymes y emprendedores a comprar mejor, reducir costos
                        y evitar errores en sus procesos. Contamos con amplia experiencia
                        negociando con proveedores en <span
                            class="font-semibold text-gray-800"
                            >China y Latinoamérica</span
                        > (como Brasil y Colombia), consiguiendo siempre los mejores
                        precios y condiciones confiables.
                    </p>
                    <p>
                        Nos encargamos de todo el proceso logístico por ti, de
                        manera completamente <span
                            class="font-semibold text-gray-800"
                            >estratégica, eficiente y sin complicaciones</span
                        >.
                    </p>
                </div>

                {/* Grid de Mini Bullets - 2 Columnas */}
                <div
                    class="grid grid-cols-1 sm:grid-cols-2 gap-y-5 gap-x-4 mb-10 bg-white p-6 rounded-2xl shadow-sm border border-gray-100"
                >
                    <div class="flex items-start gap-3">
                        <div
                            class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center"
                        >
                            <svg
                                class="w-4 h-4 text-emerald-600"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="3"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                        </div>
                        <span class="text-gray-800 font-medium"
                            >Experiencia internacional</span
                        >
                    </div>

                    <div class="flex items-start gap-3">
                        <div
                            class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center"
                        >
                            <svg
                                class="w-4 h-4 text-emerald-600"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="3"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                        </div>
                        <span class="text-gray-800 font-medium"
                            >Proveedores confiables</span
                        >
                    </div>

                    <div class="flex items-start gap-3">
                        <div
                            class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center"
                        >
                            <svg
                                class="w-4 h-4 text-emerald-600"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="3"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                        </div>
                        <span class="text-gray-800 font-medium"
                            >Reducción de costos</span
                        >
                    </div>

                    <div class="flex items-start gap-3">
                        <div
                            class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center"
                        >
                            <svg
                                class="w-4 h-4 text-emerald-600"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="3"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                        </div>
                        <span class="text-gray-800 font-medium"
                            >Gestión de inicio a fin</span
                        >
                    </div>
                </div>

                {/* Sello / Detalle Marca */}
                <div class="flex flex-col items-center justify-center w-full gap-2 pt-8 border-t border-gray-200/60 mt-4">
                    <img
                        src={logo.src}
                        alt="Sagil Logo"
                        class="w-40 md:w-48 h-auto object-contain drop-shadow-sm"
                    />
                    <p
                        class="text-sm md:text-base text-green-600 italic font-medium leading-tight text-center"
                    >
                        Gestión y estrategia de compra.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* CSS simple para animar en carga / scroll */
    .animate-fade-in-down {
        animation: fadeInDown 1s ease-out forwards;
    }
    @keyframes fadeInDown {
        0% {
            opacity: 0;
            transform: translateY(30px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .delay-100 {
        animation-delay: 100ms;
    }
    .delay-200 {
        animation-delay: 300ms;
    }
</style>
