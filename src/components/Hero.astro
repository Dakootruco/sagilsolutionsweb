---
// Hero.astro
---

<section
    class="relative w-full h-[100vh] min-h-[600px] flex items-center justify-center overflow-hidden"
>
    {/* Imagen de Fondo */}
    <div class="absolute inset-0 z-0">
        <img
            src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?q=80&w=2070&auto=format&fit=crop"
            alt="Hero Sagil Solutions"
            class="w-full h-full object-cover object-center"
        />
        {/* Capa de oscurecimiento (Overlay) y Gradiente */}
        <div class="absolute inset-0 bg-gray-900/60 mix-blend-multiply"></div>
        <div
            class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/40 to-transparent"
        >
        </div>
    </div>

    {/* Contenido principal */}
    <div
        class="relative z-10 container mx-auto px-6 lg:px-12 text-center flex flex-col items-center"
    >
        {/* Etiqueta animada */}
        <div
            class="mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-blue-400/30 bg-blue-500/10 backdrop-blur-md animate-fade-in-down"
        >
            <span
                class="flex h-2 w-2 rounded-full bg-blue-500 shadow-[0_0_10px_rgba(59,130,246,0.8)] animate-pulse"
            ></span>
            <span
                class="text-sm font-medium text-blue-200 tracking-wide uppercase"
                >Matia es gay</span
            >
        </div>

        {/* Título */}
        <h1
            class="text-5xl md:text-6xl lg:text-7xl font-bold text-white tracking-tight leading-tight mb-8 max-w-4xl drop-shadow-lg"
        >
            Gestión estratégica de Compras para <span
                class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400"
                >MIPYMES y EMPRENDEDORES</span
            >
        </h1>

        {/* Subtítulo */}
        <p
            class="text-lg md:text-xl text-gray-200 mb-10 max-w-2xl font-light leading-relaxed drop-shadow-md"
        >
            Creamos soluciones ágiles y personalizadas que impulsan el
            crecimiento, optimizan procesos y transforman ideas en realidades
            digitales.
        </p>

        {/* Botones de acción (Call to action) */}
        <div
            class="flex flex-col sm:flex-row gap-4 items-center justify-center w-full"
        >
            <a
                href="#servicios"
                class="group relative inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white transition-all duration-300 bg-blue-600 rounded-full hover:bg-blue-500 hover:shadow-[0_0_20px_rgba(59,130,246,0.5)] focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-gray-900 w-full sm:w-auto"
            >
                <span>Nuestros Servicios</span>
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
            </a>

            <a
                href="#contacto"
                class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white transition-all duration-300 bg-white/5 border border-white/20 rounded-full backdrop-blur-sm hover:bg-white/10 hover:border-white/30 focus:outline-none focus:ring-2 focus:ring-white/50 focus:ring-offset-2 focus:ring-offset-gray-900 w-full sm:w-auto"
            >
                Contáctanos
            </a>
        </div>
    </div>

    {/* Scroll indicatór animado en la parte inferior */}
    <div
        class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 mt-8 flex flex-col items-center animate-bounce"
    >
        <span class="text-sm text-gray-400 mb-2 font-light">Descubre más</span>
        <svg
            class="w-6 h-6 text-gray-400"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
    </div>
</section>

<style>
    /* Animación personalizada para que el badge baje suavemente */
    @keyframes fadeInDown {
        0% {
            opacity: 0;
            transform: translateY(-20px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-fade-in-down {
        animation: fadeInDown 0.8s ease-out forwards;
    }
</style>
